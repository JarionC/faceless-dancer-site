FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY index.html tsconfig.json vite.config.ts ./
COPY .env ./.env
COPY src ./src

ARG VITE_BEAT_API_BASE_URL=http://localhost:8787
ENV VITE_BEAT_API_BASE_URL=${VITE_BEAT_API_BASE_URL}

RUN npm run build

EXPOSE 4173

CMD ["npm", "run", "preview"]
