FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    ffmpeg \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

COPY worker/requirements.txt ./worker/requirements.txt
ENV PIP_DEFAULT_TIMEOUT=120
RUN python3 -m pip install --no-cache-dir --upgrade pip && \
    python3 -m pip install --no-cache-dir --retries 30 --resume-retries 30 torch==2.2.2 torchaudio==2.2.2 && \
    python3 -m pip install --no-cache-dir -r worker/requirements.txt

COPY worker ./worker

ENV SEPARATION_WORKER_PORT=8792
ENV SEPARATION_ENGINE=bs_roformer
ENV BS_ROFORMER_MODEL_SLUG=roformer-model-bs-roformer-sw-by-jarredou
ENV BS_ROFORMER_MODELS_DIR=/app/worker-models
ENV BS_ROFORMER_OUTPUT_DIR=/app/worker-output
ENV BS_ROFORMER_INFER_NUM_OVERLAP=8
ENV BS_ROFORMER_INFER_CHUNK_SIZE=881664
ENV BS_ROFORMER_INFER_NORMALIZE=1
ENV BS_ROFORMER_SAVE_STEMS_PER_RUN=1
ENV BS_ROFORMER_STEM_RUNS_DIR=stem-runs
ENV BEAT_ANALYSIS_TIMEOUT_SECONDS=1200
ENV BEAT_ANALYSIS_HOP_LENGTH=512
ENV BEAT_ANALYSIS_ONSET_MIN_STRENGTH=0.10
ENV BEAT_ANALYSIS_ONSET_MIN_DISTANCE_SECONDS=0.11
ENV BEAT_ANALYSIS_ADAPTIVE_WINDOW_SECONDS=0.45
ENV BEAT_ANALYSIS_STRICT_K=1.15
ENV BEAT_ANALYSIS_PERMISSIVE_K=0.62
ENV BEAT_ANALYSIS_GAP_TRIGGER_SECONDS=0.24
ENV BEAT_ANALYSIS_SUSTAIN_MIN_DURATION_SECONDS=0.08
ENV BEAT_ANALYSIS_SUSTAIN_MERGE_GAP_SECONDS=0.14
ENV BEAT_ANALYSIS_SUSTAIN_BRIDGE_FLOOR=0.25
ENV BEAT_ANALYSIS_SUSTAIN_MAX_PITCH_JUMP_SEMITONES=3.0
ENV BEAT_ANALYSIS_SUSTAIN_SPLIT_ON_PITCH_CHANGE=1
ENV BEAT_ANALYSIS_SUSTAIN_MIN_PITCH_CONFIDENCE=0.45
ENV BEAT_ANALYSIS_SUSTAIN_ENABLE_CONTINUOUS_PITCH_SPLIT=1
ENV BEAT_ANALYSIS_SUSTAIN_PITCH_SPLIT_THRESHOLD_SEMITONES=0.75
ENV BEAT_ANALYSIS_SUSTAIN_PITCH_SPLIT_MIN_SEGMENT_SECONDS=0.20
ENV BEAT_ANALYSIS_SUSTAIN_PITCH_SPLIT_MIN_VOICED_PROBABILITY=0.70
ENV BEAT_ANALYSIS_LOW_FMIN=20
ENV BEAT_ANALYSIS_LOW_FMAX=180
ENV BEAT_ANALYSIS_MID_FMIN=180
ENV BEAT_ANALYSIS_MID_FMAX=2200
ENV BEAT_ANALYSIS_HIGH_FMIN=2200
ENV BEAT_ANALYSIS_HIGH_FMAX=12000
ENV BEAT_ANALYSIS_LOW_WEIGHT=1.15
ENV BEAT_ANALYSIS_MID_WEIGHT=1.00
ENV BEAT_ANALYSIS_HIGH_WEIGHT=0.90
ENV HF_HUB_ENABLE_HF_TRANSFER=1
ENV HF_HUB_DISABLE_TELEMETRY=1

EXPOSE 8792

CMD ["python3", "worker/server.py"]
